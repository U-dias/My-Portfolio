
<h1>商品一覧</h1>

<% @products.each do |product| %>
  <div>
    <%= link_to product.name, product_path(product) %>
      <p><%= product.name %></p>
      <p><%= product.price %>円</p>

    <% product.categories.each do |category| %>
      <span><%= category.name %></span>
    <% end %>
  </div>
<% end %>
